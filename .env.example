# --- Mekari login (required — used by the Playwright cold-path login) ---
TALENTA_EMAIL=you@example.com
TALENTA_PASSWORD=replace-me

# --- Tenant + device identifiers (required) ---
# Find these by capturing a real POST to .../attendance_clocks from the
# official mobile app via a network proxy. See README "Finding your..." section.
TALENTA_COMPANY_ID=99999
TALENTA_LATITUDE=0.0
TALENTA_LONGITUDE=0.0
TALENTA_DEVICE_ID=YOUR_DEVICE_ID
TALENTA_OFFICE_HOUR_ID=123456

# --- One-time bootstrap (optional) ---
# Only used the very first run, before storage/credentials.json exists. Once a
# successful refresh or login writes that file, these env vars are ignored.
# Leaving them unset is fine — the cold path will log in via email/password.
# TALENTA_BOOTSTRAP_COOKIE=paste-document.cookie-here
# TALENTA_BOOTSTRAP_AUTH_TOKEN=paste-decoded-token-here
